# Copy to .env (git-ignored).
# ANTHROPIC_API_KEY enables AI nutrition-label extraction. Without it, label capture still
# works — it just falls back to manual entry (the /api/ai/extract-label route returns 503).
ANTHROPIC_API_KEY=
# Which Claude model to use for AI features. Defaults to Sonnet (good for vision).
# Use claude-opus-4-8 for max quality, claude-haiku-4-5 for cheapest.
# ANTHROPIC_MODEL=claude-sonnet-4-6
# PORT=3000
# DATA_DIR=./data
